server.address=${BIND_IP}
EOF
        info "application.properties written"
    else
        info "application.properties found and kept (use --force to regenerate)"
    fi

    info "Spring Boot project setup completed successfully."
}

# =============================================================================
# build_and_run() - Ultra-defensive version with repeated safe defaults
# =============================================================================
build_and_run() {
    step_message "Building and running ..."

    : "${PROJECT_DIR:=${HOME}/springboot-springboot3}"
    : "${JAR_NAME:=hello-springboot3-0.0.1.jar}"

    info "Building project with Maven..."

    mvn clean package -DskipTests || {
        warn "Maven build failed."
        printf "Debug hint: cd \"%s\" && mvn clean package -DskipTests\n" "${PROJECT_DIR}"
        printf "Check pom.xml, Java source, or network issues\n" >&2
        exit 1
    }

    local jar_path="target/${JAR_NAME}"

    if [ -f "${jar_path}" ]; then
        empty_line
        double_line
        msg "  Spring Boot ${SPRINGBOOT_VER} is starting...\n"
        msg "  → Open: http://localhost:${PORT}/\n"
        msg "  → Ctrl+C to stop\n"
        double_line
        empty_line
        empty_line

        exec java -jar "${jar_path}"
    else
        error "Maven reported success but expected JAR file is missing!"
        error "   Expected JAR : ${jar_path}"
        error "   Project dir  : ${PROJECT_DIR}"
        printf "Debug command: ls -la \"%s/target/\"\n" "${PROJECT_DIR}" >&2
        exit 1
    fi
}

# =============================================================================
# Updated help with --force behavior
# =============================================================================
show_spring3_help() {
    cat <<EOF
${APP_NAME} v${VERSION} — ${DESCRIPTION}

Usage:
  ${APP_NAME}                    Setup + build + run (preserves project on re-run)
  ${APP_NAME} --force            Full reset: delete & regenerate project files
  ${APP_NAME} version            Show version
  ${APP_NAME} version-check      Compare with latest
  ${APP_NAME} self-update        Update to latest
  ${APP_NAME} help               This help

Options:
  --version, -v        Show version information
  --version-check      Compare installed version with latest on GitHub
  --self-update        Update to the latest version from GitHub
  --force, --reinstall Force full reinstall (deletes and regenerates project)
  --quiet, -q          Suppress non-error output
  --help, -h           Show this help message

Behavior:
  • Normal run: Preserves existing project folder and source files for repeated use
  • With --force: Completely resets the project (clean rebuild)

EOF
}

# =============================================================================
# main()
# =============================================================================
main() {
    : "${HOME:=/root}"
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"

    local cmd="run"

    while [ $# -gt 0 ]; do
        case "$1" in
            --version|-v)
                cmd="version"
                ;;
            --version-check)
                cmd="version-check"
                ;;
            --self-update)
                cmd="self-update"
                ;;
            --force|--reinstall)
                FORCE_REINSTALL=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --help|-h)
                cmd="help"
                ;;
            --*)
                error "Unknown option: $1"
                printf "Try: %s --help\n" "$APP_NAME" >&2
                exit 1
                ;;
            *)
                error "Unknown argument: $1"
                printf "Try: %s --help\n" "$APP_NAME" >&2
                exit 1
                ;;
        esac
        shift
    done

    if [ "$cmd" = "version" ]; then
        printf "%s version %s\n" "${APP_NAME}" "${VERSION}"
        exit 0
    fi

    if [ "$cmd" = "self-update" ]; then
        self_update
        exit 0
    fi

    if ! is_installed; then
        maybe_install
    fi

    case "${cmd}" in
        version-check)   version_check; exit 0 ;;
        self-update)     self_update; exit 0 ;;
        help)            show_spring3_help; exit 0 ;;
        run)             ;;
        *)               die "Invalid cmd" ;;
    esac

    setup_sdkman
    setup_java
    setup_maven
    setup_springboot_project
    build_and_run
}

main "$@"