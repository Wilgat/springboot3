build_and_run() {
    step_message "Building and running ..."
    info "Building project..."
    mvn clean package -DskipTests || {
        warn "Build failed."
        printf "Debug: cd \"%s\" && mvn clean package\n" "${PROJECT_DIR}"
        exit 1
    }
    empty_line
    double_line
    msg "  Spring Boot ${SPRINGBOOT_VER} is starting...\n"
    msg "  → Open: http://localhost:${PORT}/\n"
    msg "  → Ctrl+C to stop\n"
    double_line
    empty_line
    empty_line
    exec java -jar "target/${JAR_NAME}"
}

