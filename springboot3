#!/bin/sh

# ────────────────────────────────────────────────
#  springboot3 – version 1.0.2
#  One-command installer + launcher for Spring Boot 3.x
#    • Installs itself if not present
#    • Installs SDKMAN! if missing
#    • Installs Java 21 (Temurin) – compatible with Java 25 when available
#    • Installs latest Maven 3.9.x
#    • Creates & runs minimal Spring Boot 3.3.5 Hello World
# ────────────────────────────────────────────────

VERSION="1.0.2"
APP=springboot3
GITUSER=Wilgat
JAVA_MAIN_VER=21
JAVA_BRAND=Temurin
JAVA_ID=$JAVA_MAIN_VER-tem
MAVEN_VER=3.9.12
ARTIFACT_ID=hello-$APP
ARTIFACT_VER=0.0.1
JAR_NAME=$ARTIFACT_ID-$ARTIFACT_VER.jar
SPRINGBOOT_VER=3.3.5
SPRINGBOOT_NAME=springboot-$ARTIFACT_ID
PORT=8080
BIND_IP=0.0.0.0
GITUSERCONTENT=https://raw.githubusercontent.com/$GITUSER/$APP/main/$APP
MAIN_PATH=src/main
RESOURCE_PATH=$MAIN_PATH/resources
ORG_TYPE=com
ORG_NAME=example
NAMESPACE=$ORG_TYPE.$ORG_NAME
PROJECT_DIR="$HOME/$SPRINGBOOT_NAME"

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' NC=''
fi

# ────────────────────────────────────────────────
# Installation path logic
# ────────────────────────────────────────────────

if [ "$(id -u)" -eq 0 ]; then
    INSTALL_DIR="/usr/local/bin"
    INSTALL_PATH="$INSTALL_DIR/$APP"
    NEEDS_SUDO=false
else
    INSTALL_DIR="${HOME}/.local/bin"
    INSTALL_PATH="$INSTALL_DIR/$APP"
    NEEDS_SUDO=true
fi

# ────────────────────────────────────────────────
# Helpers
# ────────────────────────────────────────────────

is_installed() {
    [ -f "$INSTALL_PATH" ] && [ -x "$INSTALL_PATH" ]
}

in_path() {
    case ":${PATH}:" in
        *:"${INSTALL_DIR}":*) return 0 ;;
        *) return 1 ;;
    esac
}

add_to_bashrc() {
    local bashrc="${HOME}/.bashrc"
    local line="export PATH=\"\$HOME/.local/bin:\$PATH\""

    if [ -f "$bashrc" ] && grep -qF "$line" "$bashrc" 2>/dev/null; then
        return
    fi

    echo "" >> "$bashrc"
    echo "# Added by $APP installer" >> "$bashrc"
    echo "$line" >> "$bashrc"
    echo "${YELLOW}→ Added ~/.local/bin to PATH in ~/.bashrc${NC}"
}

# ────────────────────────────────────────────────
# Self-install logic – continues after install
# ────────────────────────────────────────────────

install_self() {
    echo ""
    echo "${YELLOW}$APP not found → installing...${NC}"
    echo ""

    if $NEEDS_SUDO; then
        echo "Recommended install command (use bash explicitly):"
        echo "  ${GREEN}sudo curl -fsSL $GITUSERCONTENT | sudo bash${NC}"
    else
        echo "Recommended install command (use bash explicitly):"
        echo "  ${GREEN}curl -fsSL $GITUSERCONTENT | bash${NC}"
    fi

    echo ""

    mkdir -p "$INSTALL_DIR" 2>/dev/null || {
        echo "${RED}Cannot create directory $INSTALL_DIR${NC}" >&2
        exit 1
    }

    TMP_SCRIPT="/tmp/$APP_$$.sh"
    if ! curl -fsSL "$GITUSERCONTENT" -o "$TMP_SCRIPT"; then
        echo "${RED}Failed to download installer${NC}" >&2
        rm -f "$TMP_SCRIPT" 2>/dev/null
        exit 1
    fi

    chmod 755 "$TMP_SCRIPT" || {
        echo "${RED}chmod failed${NC}" >&2
        rm -f "$TMP_SCRIPT"
        exit 1
    }

    if cp "$TMP_SCRIPT" "$INSTALL_PATH" 2>/dev/null; then
        echo "${GREEN}Installed to $INSTALL_PATH${NC}"
        rm -f "$TMP_SCRIPT"
        
        if ! $NEEDS_SUDO && ! in_path; then
            add_to_bashrc
            echo ""
            echo "${YELLOW}→ ~/.local/bin was added to ~/.bashrc${NC}"
            echo "  To use '$APP' immediately in this session run:"
            echo "    ${GREEN}. ~/.bashrc${NC}"
            echo "  (or open a new terminal)"
            echo "  Continuing in current session anyway..."
        fi

        echo "${GREEN}Proceeding to setup SDKMAN + Java $JAVA_MAIN_VER + Maven + Spring Boot 3 demo...${NC}"
        echo ""
    else
        echo "${RED}Failed to install to $INSTALL_PATH${NC}" >&2
        echo "  Permission denied? Try with sudo."
        rm -f "$TMP_SCRIPT"
        exit 1
    fi
}

# ────────────────────────────────────────────────
# Help
# ────────────────────────────────────────────────

show_help() {
    cat << 'EOF'
$APP – version $VERSION

One-command modern Spring Boot 3.x environment setup

Usage:
  $APP               Setup tools (if needed) + create + build + run demo
  $APP help          Show this help
  $APP version       Show version

What it does:
  • Installs itself to ~/.local/bin or /usr/local/bin if missing
  • Installs SDKMAN! (if not present)
  • Installs Java $JAVA_MAIN_VER ($JAVA_BRAND – LTS, compatible with upcoming Java 25)
  • Installs Maven $MAVEN_VER
  • Creates ~/$PRINGBOOT_NAME (Spring Boot $SPRINGBOOT_VER minimal project)
  • Builds & runs it[](http://localhost:$PORT)

Note: First time SDKMAN is installed, you may need to run
      . "$HOME/.sdkman/bin/sdkman-init.sh"  or open new terminal
      before 'sdk' command becomes available in current session.

EOF
}

# ────────────────────────────────────────────────
# Argument parsing
# ────────────────────────────────────────────────

COMMAND="run"

while [ $# -gt 0 ]; do
    case "$1" in
        version) COMMAND="version"; shift ;;
        help)    COMMAND="help";    shift ;;
        *)       echo "${RED}Unknown argument: $1${NC}" >&2
                 echo "Try: $APP help"
                 exit 1 ;;
    esac
done

# ────────────────────────────────────────────────
# Install if missing → then continue anyway
# ────────────────────────────────────────────────

if ! is_installed; then
    install_self
fi

# ────────────────────────────────────────────────
# Execute requested command
# ────────────────────────────────────────────────

case "$COMMAND" in
    version)
        echo "$APP version $VERSION"
        exit 0
        ;;

    help)
        show_help
        exit 0
        ;;

    run) : ;;  # continue to setup & run
    *)
        echo "${RED}Invalid command${NC}" >&2
        exit 1
        ;;
esac

# ────────────────────────────────────────────────
# Main payload: SDKMAN + Java $JAVA_MAIN_VER + Maven + Spring Boot 3 demo
# ────────────────────────────────────────────────

echo ""
echo "=============================================================="
echo "  $APP  –  SDKMAN + Java $JAVA_MAIN_VER + Maven + Spring Boot 3.3"
echo "=============================================================="
echo ""

# 1. SDKMAN
echo "→ Checking SDKMAN..."
if [ -d "$HOME/.sdkman" ] && command -v sdk >/dev/null 2>&1; then
    echo "   Already installed."
else
    echo "   Installing SDKMAN..."
    curl -s "https://get.sdkman.io" | bash
    [ $? -ne 0 ] && { echo "${RED}SDKMAN install failed${NC}"; exit 1; }

    echo "   Loading SDKMAN in current session..."
    if [ -s "$HOME/.sdkman/bin/sdkman-init.sh" ]; then
        . "$HOME/.sdkman/bin/sdkman-init.sh"
    else
        echo "${YELLOW}Warning: sdkman-init.sh not found${NC}"
    fi
fi

if ! command -v sdk >/dev/null 2>&1; then
    echo ""
    echo "${YELLOW}sdk command is still not available in this session.${NC}"
    echo "This is normal on first SDKMAN install."
    echo ""
    echo "Please run one of these, then re-execute '$APP':"
    echo "  ${GREEN}. \"\$HOME/.sdkman/bin/sdkman-init.sh\"${NC}"
    echo "  ${GREEN}. ~/.bashrc${NC}"
    echo "  or open a new terminal / tab"
    echo ""
    exit 1
fi

echo "   SDKMAN ready."
sdk version | head -n 1

# 2. Java $JAVA_MAIN_VER ($JAVA_BRAND – current LTS, change to 25-tem when available)
echo ""
echo "→ Installing Java $JAVA_MAIN_VER ($JAVA_BRAND)..."

sdk install java $JAVA_ID </dev/null || {
    echo "${RED}Failed to install Java $JAVA_MAIN_VER $JAVA_BRAND${NC}"
    echo "Run 'sdk list java' to see available versions"
    exit 1
}

sdk default java $JAVA_ID >/dev/null 2>&1
sdk use   java $JAVA_ID >/dev/null 2>&1 || true

java -version 2>&1 | head -n 1 || {
    echo "${RED}java command not found after install${NC}"
    exit 1
}

# 3. Maven
echo ""
echo "→ Installing Maven $MAVEN_VER..."

sdk install maven $MAVEN_VER </dev/null || {
    echo "${RED}Failed to install Maven $MAVEN_VER${NC}"
    exit 1
}

sdk default maven $MAVEN_VER >/dev/null 2>&1
sdk use   maven $MAVEN_VER >/dev/null 2>&1 || true

mvn --version | head -n 3 || {
    echo "${RED}mvn command not found${NC}"
    exit 1
}

# 4. Create minimal Spring Boot $SPRINGBOOT_VER project

echo ""
echo "→ Creating minimal Spring Boot $SPRINGBOOT_VER project..."
echo "→   Location: $PROJECT_DIR"


[ -d "$PROJECT_DIR" ] && {
    echo "   Removing previous project folder..."
    rm -rf "$PROJECT_DIR"
}

mkdir -p "$PROJECT_DIR"
cd "$PROJECT_DIR" || exit 1

cat > pom.xml << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>$NAMESPACE</groupId>
    <artifactId>$ARTIFACT_ID</artifactId>
    <version>$ARTIFACT_VER</version>
    <packaging>jar</packaging>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>$SPRINGBOOT_VER</version>
    </parent>

    <properties>
        <java.version>$JAVA_MAIN_VER</java.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
EOF

mkdir -p $MAIN_PATH/java/$ORG_TYPE/$ORG_NAME
cat > $MAIN_PATH/java/$ORG_TYPE/$ORG_NAME/HelloApplication.java << 'EOF'
package $NAMESPACE;

import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@SpringBootApplication
@RestController
public class HelloApplication {

    public static void main(String[] args) {
        SpringApplication.run(HelloApplication.class, args);
    }

    @GetMapping("/")
    public String home() {
        return """
               Hello from Spring Boot $SPRINGBOOT_VER!
               Running on Java $JAVA_MAIN_VER (ready for Java 25)
               """;
    }
}
EOF

mkdir -p $RESOURCE_PATH
cat > $RESOURCE_PATH/application.properties << 'EOF'
server.port=$PORT
server.address=$BIND_IP
EOF

echo "   Project created in: $PROJECT_DIR"

# 5. Build & run
echo ""
echo "→ Building application..."

mvn clean package -DskipTests || {
    echo "${RED}Build failed${NC}"
    echo "You can try: cd $PROJECT_DIR && mvn clean package"
    exit 1
}

echo ""
echo "=============================================================="
echo "  Spring Boot $SPRINGBOOT_VER app is starting..."
echo "  → Open: http://localhost:$PORT"
echo "  → Press Ctrl+C to stop"
echo "=============================================================="
echo ""

java -jar target/$JAR_NAME