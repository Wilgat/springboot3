            </plugin>
        </plugins>
    </build>
</project>
EOF
    else
        info "pom.xml found and kept (use --force to regenerate)"
    fi

    # Java source directory
    if [ ! -d "src/main/java/com/example" ] || [ "1" = "${FORCE_REINSTALL}" ]; then
        if [ "1" = "${FORCE_REINSTALL}" ] && [ -d "src/main/java/com/example" ]; then
            info "Force reinstall → removing old src/main/java/com/example"
            rm -rf "src/main/java/com/example"
        fi
        mkdir -p "src/main/java/com/example" || die "Cannot create source directory"
    else
        info "Source directory src/main/java/com/example found and kept"
    fi

    # ${MAIN_CLASS}.java
    if [ ! -f "src/main/java/com/example/${MAIN_CLASS}.java" ] || [ "1" = "${FORCE_REINSTALL}" ]; then
        if [ "1" = "${FORCE_REINSTALL}" ] && [ -f "src/main/java/com/example/${MAIN_CLASS}.java" ]; then
            rm -f "src/main/java/com/example/${MAIN_CLASS}.java"
        fi
        write_file_atomic "src/main/java/com/example/${MAIN_CLASS}.java" <<EOF
