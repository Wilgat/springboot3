#!/bin/bash
# ────────────────────────────────────────────────────────────────
#  springboot3 – version 1.0.14
#  One-command installer + launcher for Spring Boot 3.x
#
#  Installs (if needed):
#    • itself (~/.local/bin or /usr/local/bin)
#    • SDKMAN!
#    • Java 21 (Temurin)
#    • Maven 3.9.9
#    • Creates & runs minimal Spring Boot 3.3.5 Hello World
#
#  One-liner install (recommended):
#    curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot3/main/springboot3 | bash
#    sudo curl -fsSL https://raw.githubusercontent.com/Wilgat/springboot3/main/springboot3 | sudo bash
# ────────────────────────────────────────────────────────────────

# ─── Constants ───────────────────────────────────────────────────

APP_NAME="springboot3"
APP_VERSION="1.0.14"

GLOBAL_BIN="/usr/local/bin"
USER_BIN="${HOME}/.local/bin"

SCRIPT_REPO_USER="Wilgat"
SCRIPT_REPO_NAME="${APP_NAME}"
SCRIPT_URL="https://raw.githubusercontent.com/${SCRIPT_REPO_USER}/${SCRIPT_REPO_NAME}/main/${APP_NAME}"

# Tool versions
JAVA_MAIN_VER=21
JAVA_DISTRIBUTION="temurin"
JAVA_SDK_ID="${JAVA_MAIN_VER}-${JAVA_DISTRIBUTION}"

MAVEN_VERSION="3.9.9"

SPRING_BOOT_VERSION="3.3.5"
PROJECT_NAME="springboot-hello-${APP_NAME}"
PROJECT_DIR="${HOME}/${PROJECT_NAME}"

SERVER_PORT=8080
SERVER_BIND="0.0.0.0"

GROUP_ID="com.example"
ARTIFACT_ID="hello-${APP_NAME}"
MAIN_CLASS="HelloApplication"
JAR_NAME="${ARTIFACT_ID}-0.0.1.jar"

# ─── Colors (only when terminal) ─────────────────────────────────

if [ -t 1 ]; then
    C_GREEN='\033[0;32m'
    C_YELLOW='\033[1;33m'
    C_RED='\033[0;31m'
    C_RESET='\033[0m'
else
    C_GREEN='' C_YELLOW='' C_RED='' C_RESET=''
fi

# ─── Install location logic ──────────────────────────────────────

if [ "$(id -u)" -eq 0 ]; then
    IS_ROOT=1
    INSTALL_DIR="${GLOBAL_BIN}"
else
    IS_ROOT=0
    INSTALL_DIR="${USER_BIN}"
fi

INSTALL_PATH="${INSTALL_DIR}/${APP_NAME}"

# ─── Helper functions ────────────────────────────────────────────

is_installed() {
    if [ "$IS_ROOT" -eq 1 ]; then
        [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ]
    else
        { [ -f "${GLOBAL_BIN}/${APP_NAME}" ] && [ -x "${GLOBAL_BIN}/${APP_NAME}" ]; } ||
        { [ -f "${USER_BIN}/${APP_NAME}"   ] && [ -x "${USER_BIN}/${APP_NAME}"   ]; }
    fi
}

in_path() {
    case ":${PATH}:" in
        *:"${INSTALL_DIR}":*) return 0 ;;
        *) return 1 ;;
    esac
}

add_to_bashrc() {
    local bashrc="${HOME}/.bashrc"
    local line="export PATH=\"\$HOME/.local/bin:\$PATH\""

    [ -f "$bashrc" ] && grep -qF "$line" "$bashrc" 2>/dev/null && return 0

    printf "\n"                          >> "$bashrc"
    printf "# Added by %s installer\n" "$APP_NAME" >> "$bashrc"
    printf "%s\n" "$line"                >> "$bashrc"

    printf "${C_YELLOW}→ Added ~/.local/bin to PATH in ~/.bashrc${C_RESET}\n"
}

perform_self_install() {
    printf "\n${C_YELLOW}%s not found → installing...${C_RESET}\n\n" "$APP_NAME"

    if [ "$IS_ROOT" -eq 1 ]; then
        printf "Recommended install command:\n"
        printf "  ${C_GREEN}sudo curl -fsSL %s | sudo bash${C_RESET}\n\n" "$SCRIPT_URL"
    else
        printf "Recommended install command:\n"
        printf "  ${C_GREEN}curl -fsSL %s | bash${C_RESET}\n\n" "$SCRIPT_URL"
    fi

    mkdir -p "${INSTALL_DIR}" 2>/dev/null || {
        printf "${C_RED}Cannot create directory %s${C_RESET}\n" "${INSTALL_DIR}" >&2
        exit 1
    }

    local tmp
    tmp=$(mktemp "/tmp/${APP_NAME}.XXXXXXXX") || {
        printf "${C_RED}mktemp failed${C_RESET}\n" >&2
        exit 1
    }

    if ! curl -fsSL "$SCRIPT_URL" -o "$tmp"; then
        printf "${C_RED}Failed to download script${C_RESET}\n" >&2
        rm -f "$tmp"
        exit 1
    fi

    chmod 755 "$tmp" || {
        printf "${C_RED}chmod failed${C_RESET}\n" >&2
        rm -f "$tmp"
        exit 1
    }

    if mv "$tmp" "$INSTALL_PATH" 2>/dev/null; then
        printf "${C_GREEN}Installed to %s${C_RESET}\n" "$INSTALL_PATH"
    else
        printf "${C_RED}Failed to install to %s${C_RESET}\n" "$INSTALL_PATH" >&2
        printf "Permission denied? Try with sudo.\n"
        rm -f "$tmp"
        exit 1
    fi

    if [ "$IS_ROOT" -eq 0 ] && ! in_path; then
        add_to_bashrc
        printf "\n"
        printf "${C_YELLOW}Important:${C_RESET} ~/.local/bin was not in your PATH.\n"
        printf "          We added it to ~/.bashrc.\n\n"
        printf "          Please run one of these now:\n"
        printf "            ${C_GREEN}. ~/.bashrc${C_RESET}\n"
        printf "          or open a new terminal.\n\n"
        printf "Continuing in current session anyway...\n\n"
    fi

    printf "${C_GREEN}Proceeding with SDKMAN + Java + Maven + demo setup...${C_RESET}\n\n"
}

maybe_self_install() {
    is_installed && return 0
    perform_self_install
}

show_help() {
    cat <<EOF
${APP_NAME} – version ${APP_VERSION}

One-command Spring Boot 3.x environment setup + minimal demo

Usage:
  ${APP_NAME}               Setup tools (if needed) + create + build + run demo
  ${APP_NAME} help          Show this help
  ${APP_NAME} version       Show version

What it does:
  • Installs itself to ~/.local/bin (or /usr/local/bin if root)
  • Installs SDKMAN! (if missing)
  • Installs Java ${JAVA_MAIN_VER} (${JAVA_DISTRIBUTION})
  • Installs Maven ${MAVEN_VERSION}
  • Creates ~/${PROJECT_NAME} (minimal Spring Boot ${SPRING_BOOT_VERSION} project)
  • Builds & runs it → open http://localhost:${SERVER_PORT}

Note: After first SDKMAN install you may need to run
      . "\$HOME/.sdkman/bin/sdkman-init.sh"
      or open a new terminal before 'sdk' works in current session.

EOF
}

parse_arguments() {
    while [ $# -gt 0 ]; do
        case "$1" in
            help|--help|-h)     show_help; exit 0 ;;
            version|--version)  printf "%s version %s\n" "$APP_NAME" "$APP_VERSION"; exit 0 ;;
            *)  printf "${C_RED}Unknown argument: %s${C_RESET}\n" "$1" >&2
                printf "Try: %s help\n" "$APP_NAME"
                exit 1 ;;
        esac
    done
}

setup_sdkman() {
    printf "→ Checking SDKMAN...\n"
    if [ -d "${HOME}/.sdkman" ] && command -v sdk >/dev/null 2>&1; then
        printf "   Already installed.\n"
    else
        printf "   Installing SDKMAN...\n"
        curl -s "https://get.sdkman.io" | bash
        [ $? -ne 0 ] && { printf "${C_RED}SDKMAN install failed${C_RESET}\n"; exit 1; }

        # shellcheck disable=SC1091
        [ -s "${HOME}/.sdkman/bin/sdkman-init.sh" ] && . "${HOME}/.sdkman/bin/sdkman-init.sh"
    fi

    if ! command -v sdk >/dev/null 2>&1; then
        printf "\n${C_YELLOW}sdk command not available yet in this session.${C_RESET}\n"
        printf "This is normal after fresh SDKMAN install.\n\n"
        printf "Please run:\n"
        printf "  ${C_GREEN}. \"\$HOME/.sdkman/bin/sdkman-init.sh\"${C_RESET}\n"
        printf "  or open a new terminal,\n"
        printf "  then re-run %s\n\n" "$APP_NAME"
        exit 1
    fi

    printf "   SDKMAN ready. "
    sdk version | head -n 1
}

setup_java() {
    printf "\n→ Installing Java %s (%s)...\n" "$JAVA_MAIN_VER" "$JAVA_DISTRIBUTION"
    sdk install java "${JAVA_SDK_ID}" </dev/null || {
        printf "${C_RED}Failed to install Java %s %s${C_RESET}\n" "$JAVA_MAIN_VER" "$JAVA_DISTRIBUTION"
        printf "Run 'sdk list java' to see available versions\n"
        exit 1
    }

    sdk default java "${JAVA_SDK_ID}" >/dev/null 2>&1
    sdk use java "${JAVA_SDK_ID}" >/dev/null 2>&1 || true

    local java_bin
    java_bin="$(sdk home java current)/bin/java"
    if [ -x "$java_bin" ]; then
        "$java_bin" -version 2>&1 | head -n 1
    else
        java -version 2>&1 | head -n 1 || {
            printf "${C_RED}java command not found after install${C_RESET}\n"
            exit 1
        }
    fi
}

setup_maven() {
    printf "\n→ Installing Maven %s...\n" "$MAVEN_VERSION"
    sdk install maven "${MAVEN_VERSION}" </dev/null || {
        printf "${C_RED}Failed to install Maven %s${C_RESET}\n" "$MAVEN_VERSION"
        exit 1
    }

    sdk default maven "${MAVEN_VERSION}" >/dev/null 2>&1
    sdk use maven "${MAVEN_VERSION}" >/dev/null 2>&1 || true

    mvn --version | head -n 3 || {
        printf "${C_RED}mvn command not found${C_RESET}\n"
        exit 1
    }
}

setup_spring_project() {
    printf "\n→ Creating minimal Spring Boot %s project...\n" "$SPRING_BOOT_VERSION"
    printf "   Location: %s\n" "$PROJECT_DIR"

    [ -d "$PROJECT_DIR" ] && {
        printf "   Removing previous project folder...\n"
        rm -rf "$PROJECT_DIR"
    }

    mkdir -p "$PROJECT_DIR" || exit 1
    cd "$PROJECT_DIR" || exit 1

    # ── pom.xml ───────────────────────────────────────
    cat > pom.xml <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>${GROUP_ID}</groupId>
    <artifactId>${ARTIFACT_ID}</artifactId>
    <version>0.0.1</version>
    <packaging>jar</packaging>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>${SPRING_BOOT_VERSION}</version>
        <relativePath/>
    </parent>

    <properties>
        <java.version>${JAVA_MAIN_VER}</java.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
EOF

    # ── Main class ────────────────────────────────────
    local pkg_dir
    pkg_dir=$(echo "${GROUP_ID}" | tr '.' '/')
    local class_path="src/main/java/${pkg_dir}"
    mkdir -p "${class_path}"

    cat > "${class_path}/${MAIN_CLASS}.java" <<EOF
package ${GROUP_ID};

import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RestController;

@SpringBootApplication
@RestController
public class ${MAIN_CLASS} {

    public static void main(String[] args) {
        SpringApplication.run(${MAIN_CLASS}.class, args);
    }

    @GetMapping("/")
    public String home() {
        return "Hello from Spring Boot ${SPRING_BOOT_VERSION}!<br>\\n" +
               "Running on Java ${JAVA_MAIN_VER} (${JAVA_DISTRIBUTION})<br>\\n";
    }
}
EOF

    # ── application.properties ────────────────────────
    mkdir -p src/main/resources
    cat > src/main/resources/application.properties <<EOF
server.port=${SERVER_PORT}
server.address=${SERVER_BIND}
EOF

    printf "   Project structure created.\n"
}

build_and_run() {
    printf "\n→ Building application...\n"

    mvn clean package -DskipTests || {
        printf "${C_RED}Build failed${C_RESET}\n"
        printf "You can debug manually:\n"
        printf "  cd %s && mvn clean package\n" "$PROJECT_DIR"
        exit 1
    }

    printf "\n"
    printf "==============================================================\n"
    printf "  Spring Boot %s app is starting...\n" "$SPRING_BOOT_VERSION"
    printf "  → Open: http://localhost:%s\n" "$SERVER_PORT"
    printf "  → Press Ctrl+C to stop\n"
    printf "==============================================================\n\n"

    local java_bin
    java_bin="$(sdk home java current)/bin/java"
    if [ -x "$java_bin" ]; then
        exec "$java_bin" -jar "target/${JAR_NAME}"
    else
        exec java -jar "target/${JAR_NAME}"
    fi
}

main() {
    parse_arguments "$@"
    maybe_self_install

    cat <<EOF
==============================================================
  ${APP_NAME} ${APP_VERSION}  –  Spring Boot ${SPRING_BOOT_VERSION} Quick Start
==============================================================

EOF

    setup_sdkman
    setup_java
    setup_maven
    setup_spring_project
    build_and_run
}

main "$@"