main() {
    : "${HOME:=/root}"
    : "${GLOBAL_BIN:=/usr/local/bin}"
    : "${USER_BIN:=${HOME}/.local/bin}"

    # Default action
    local cmd="run"

    while [ $# -gt 0 ]; do
        case "$1" in
            --version|-v)
                cmd="version"
                ;;
            --version-check)
                cmd="version-check"
                ;;
            --self-update)
                cmd="self-update"
                ;;
            --force|--reinstall)
                FORCE_REINSTALL=1
                ;;
            --quiet|-q)
                QUIET=1
                ;;
            --help|-h)
                cmd="help"
                ;;
            --*)
                error "Unknown option: $1"
                printf "Try: %s --help\n" "$APP_NAME" >&2
                exit 1
                ;;
            *)
                error "Unknown argument: $1"
                printf "Try: %s --help\n" "$APP_NAME" >&2
                exit 1
                ;;
        esac
        shift
    done

    # Special handling for version-check and self-update (can run even if not installed)
    if [ "$cmd" = "version" ]; then
        printf "%s version %s\n" "${APP_NAME}" "${VERSION}"
        exit 0
    fi


    if [ "$cmd" = "self-update" ]; then
        self_update
        exit 0
    fi

    if ! is_installed; then
        maybe_install
    fi

    case "${cmd}" in
        version-check)   version_check; exit 0 ;;
        self-update)     self_update; exit 0 ;;
        help)            show_help; exit 0 ;;
        run)             ;;
        *)               die "Invalid cmd" ;;
    esac

    setup_sdkman
    setup_java
    setup_maven
    setup_springboot_project
    build_and_run
}

main "$@"